{
  "name": "sandbox-clicksign",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Integração de teste com o sandbox da Clicksign (API v3 - Envelopes)",
  "scripts": {
    "start": "node --env-file=.env src/index.ts",
